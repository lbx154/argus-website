---
import SiteLayout from "../layouts/SiteLayout.astro";
import { localeFromPath, pathForLocale } from "../i18n";

const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => pathForLocale(path, locale);
const copy = locale === "zh" ? {
  title: "Release 与安装 · Argus",
  description: "Argus Binary Preview 的 npm 内测安装方式、平台支持、版本状态与更新命令。npm Beta 先行，核心代码 Coming Soon。",
  eyebrow: "Binary Preview · 0.1.1",
  hero: "通过 npm 安装 Argus。",
  lede: "代码 Coming Soon。第一阶段先通过 npm Binary Preview 开放二进制内测，收集真实安装、平台兼容与长期运行反馈。",
  pending: "代码 Coming Soon · npm Beta 先行",
  pendingBody: "Linux x64 与 Windows Terminal / PowerShell 版本均已通过原生 CI 构建、测试、二进制 smoke 与 npm 包检查。首批内测通过 npm 的 beta 通道发布，核心代码将在发布治理与贡献流程准备完成后开放。",
  updated: "状态更新：2026 年 7 月 16 日",
  installTitle: "安装 Argus Beta",
  installBody: "Linux x64 与 Windows x64 可直接安装原生二进制；也可通过单一 npm 包安装，npm 路径需要 Node.js 18 或更高版本。",
  linuxInstallLabel: "Linux x64",
  windowsInstallLabel: "Windows x64",
  installLabel: "npm 备用安装",
  setupLabel: "首次配置",
  launchLabel: "启动 Terminal cockpit",
  webLabel: "启动 Web cockpit",
  stepsLabel: "安装步骤",
  steps: [
    ["01", "安装", "官网脚本或 npm 只下载与你的平台匹配的原生二进制。"],
    ["02", "配置", "运行交互式 setup，配置模型后端、API 与机器规则。"],
    ["03", "启动", "在项目目录运行 argus；同一会话也可切换到 Web cockpit。"],
  ],
  platformsTitle: "首发平台",
  platformsBody: "第一阶段只覆盖日常 Terminal / PowerShell 使用，不安装系统服务。",
  platforms: [
    ["Linux x64", "Validated", "单文件二进制已完成构建、npm 安装和端到端后端拉起验证。"],
    ["Windows x64", "Validated", "面向 Windows Terminal、PowerShell 与经典控制台；真实 .exe 已通过 Windows runner 构建和 smoke test。"],
  ],
  packageTitle: "包里有什么",
  packageBody: "用户只面对一个 npm 包名；平台二进制以同一包名的版本变体发布。",
  packageFacts: [
    ["@argusevolve/argus", "单一包名", "命令入口、平台选择与 Linux / Windows 版本变体"],
    ["原生二进制", "按平台下载", "argus-core 可执行文件、SHA-256 与第三方许可证清单"],
    ["核心代码", "Coming Soon", "内测阶段先验证二进制发行；源码、贡献规范与开发文档随后开放"],
  ],
  releaseTitle: "0.1.1 Binary Preview",
  releasePoints: [
    "Terminal 与 Web cockpit，共享 Manager、Planner、Engineer、Reviewer 状态",
    "后端自动启动、版本握手、真实 PID 所有权与安全停止",
    "单一 npm 包名下的 Linux x64 与 Windows x64 平台版本",
    "npm Beta 先行收集安装与运行反馈；核心代码 Coming Soon",
  ],
  limitsTitle: "Preview 边界",
  limits: [
    "Windows 首版不安装 Windows Service，不承诺关闭所有终端或重启后继续运行。",
    "Qlib、LightGBM、PyTorch 与私有市场数据集成不进入核心包，后续作为可选量化 runtime 提供。",
    "二进制分发避免直接公开源码，但不是不可逆向的密码学安全边界。",
  ],
  updateTitle: "更新与卸载",
  updateLabel: "更新 Beta",
  uninstallLabel: "卸载",
  demo: "先看真实运行 →",
  research: "浏览公开研究 →",
} : {
  title: "Release & Installation · Argus",
  description: "npm beta installation, platform support, release status, and update commands for the Argus Binary Preview. npm beta comes first; core code is coming soon.",
  eyebrow: "Binary Preview · 0.1.1",
  hero: "Install Argus from npm.",
  lede: "Code is coming soon. The first phase opens a binary npm preview to collect real installation, compatibility, and long-running feedback.",
  pending: "Code coming soon · npm beta first",
  pendingBody: "Linux x64 and Windows Terminal / PowerShell have both passed native CI builds, tests, binary smoke checks, and npm package verification. The first testers install through npm's beta channel; core code follows once release governance and contribution workflows are ready.",
  updated: "Status updated July 16, 2026",
  installTitle: "Install the Argus beta",
  installBody: "Linux x64 and Windows x64 can install the native binary directly. The single-package npm alternative requires Node.js 18 or newer.",
  linuxInstallLabel: "Linux x64",
  windowsInstallLabel: "Windows x64",
  installLabel: "npm alternative",
  setupLabel: "First-time setup",
  launchLabel: "Launch the Terminal cockpit",
  webLabel: "Launch the Web cockpit",
  stepsLabel: "Installation steps",
  steps: [
    ["01", "Install", "The official installer or npm downloads only the native binary for your platform."],
    ["02", "Configure", "Run the guided setup for model backends, API access, and machine policy."],
    ["03", "Launch", "Run argus from a project directory, or switch the same session to the Web cockpit."],
  ],
  platformsTitle: "Initial platforms",
  platformsBody: "The first release targets everyday terminal use and does not install an operating-system service.",
  platforms: [
    ["Linux x64", "Validated", "The single-file binary passed build, npm installation, and end-to-end backend startup tests."],
    ["Windows x64", "Validated", "Targets Windows Terminal, PowerShell, and the classic console; the real .exe passed build and smoke tests on the Windows runner."],
  ],
  packageTitle: "What ships",
  packageBody: "Users see one npm package name; native binaries ship as platform-specific versions of that same package.",
  packageFacts: [
    ["@argusevolve/argus", "One package name", "Command shims, platform selection, and Linux / Windows variants"],
    ["Native binary", "Downloaded per platform", "argus-core executable, SHA-256, and third-party notices"],
    ["Core code", "Coming soon", "The beta validates binary distribution first; source, contribution rules, and developer docs follow"],
  ],
  releaseTitle: "0.1.1 Binary Preview",
  releasePoints: [
    "Terminal and Web cockpits with shared Manager, Planner, Engineer, and Reviewer state",
    "Automatic backend startup, release handshake, real PID ownership, and clean shutdown",
    "Linux x64 and Windows x64 variants under one npm package name",
    "npm beta comes first for installation and runtime feedback; core code is coming soon",
  ],
  limitsTitle: "Preview boundaries",
  limits: [
    "The first Windows build does not install a Windows Service or promise survival after all terminals close or the machine restarts.",
    "Qlib, LightGBM, PyTorch, and private market-data integrations are excluded from the core package and will arrive as an optional quant runtime.",
    "Binary distribution avoids direct source publication, but it is not a cryptographic barrier against reverse engineering.",
  ],
  updateTitle: "Update or remove",
  updateLabel: "Update beta",
  uninstallLabel: "Uninstall",
  demo: "Watch real runs →",
  research: "Browse public research →",
};
---

<SiteLayout title={copy.title} description={copy.description}>
  <section class="page-hero compact release-hero">
    <div class="shell release-shell">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.hero}</h1>
      <p class="lede">{copy.lede}</p>
      <div class="release-status" role="status">
        <div>
          <span class="release-status__dot" aria-hidden="true"></span>
          <strong>{copy.pending}</strong>
        </div>
        <p>{copy.pendingBody}</p>
        <small>{copy.updated}</small>
      </div>
      <div class="hero-actions">
        <a class="button primary" href="#install">{copy.installTitle}</a>
        <a class="button" href={href("/start.html")}>{copy.demo}</a>
      </div>
    </div>
  </section>

  <section id="install" class="section release-install">
    <div class="shell release-shell">
      <div class="section-head">
        <p class="eyebrow">npm</p>
        <h2>{copy.installTitle}</h2>
        <p>{copy.installBody}</p>
      </div>
      <div class="install-grid">
        <div class="install-command-stack">
          {[
            [copy.linuxInstallLabel, "curl -fsSL https://argusbot.cn/argus/install.sh | sh"],
            [copy.windowsInstallLabel, "powershell -ExecutionPolicy ByPass -c \"irm https://argusbot.cn/argus/install.ps1 | iex\""],
            [copy.installLabel, "npm install -g @argusevolve/argus@beta"],
            [copy.setupLabel, "argus --setup"],
            [copy.launchLabel, "argus"],
            [copy.webLabel, "argus --web"],
          ].map(([label, command]) => (
            <div class="install-command">
              <span>{label}</span>
              <code>{command}</code>
            </div>
          ))}
        </div>
        <div class="install-steps" aria-label={copy.stepsLabel}>
          {copy.steps.map(([number, title, body]) => (
            <article><span>{number}</span><div><h3>{title}</h3><p>{body}</p></div></article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section surface">
    <div class="shell release-shell">
      <div class="section-head">
        <p class="eyebrow">Platforms</p>
        <h2>{copy.platformsTitle}</h2>
        <p>{copy.platformsBody}</p>
      </div>
      <div class="release-platforms">
        {copy.platforms.map(([name, status, body]) => (
          <article><div><h3>{name}</h3><span>{status}</span></div><p>{body}</p></article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell release-shell release-two-column">
      <div>
        <div class="section-head">
          <p class="eyebrow">Distribution</p>
          <h2>{copy.packageTitle}</h2>
          <p>{copy.packageBody}</p>
        </div>
        <div class="package-facts">
          {copy.packageFacts.map(([name, value, body]) => (
            <div><strong>{name}</strong><span>{value}</span><p>{body}</p></div>
          ))}
        </div>
      </div>
      <aside class="release-notes">
        <p class="eyebrow">Release notes</p>
        <h2>{copy.releaseTitle}</h2>
        <ul>{copy.releasePoints.map((point) => <li>{point}</li>)}</ul>
      </aside>
    </div>
  </section>

  <section class="section surface">
    <div class="shell release-shell release-two-column">
      <div class="release-limits">
        <p class="eyebrow">Scope</p>
        <h2>{copy.limitsTitle}</h2>
        <ul>{copy.limits.map((point) => <li>{point}</li>)}</ul>
      </div>
      <div>
        <div class="section-head compact-head">
          <p class="eyebrow">Lifecycle</p>
          <h2>{copy.updateTitle}</h2>
        </div>
        <div class="install-command-stack compact-commands">
          <div class="install-command"><span>{copy.updateLabel}</span><code>npm install -g @argusevolve/argus@beta</code></div>
          <div class="install-command"><span>{copy.uninstallLabel}</span><code>npm uninstall -g @argusevolve/argus</code></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell release-shell">
      <div class="cta-band product-cta">
        <h2>{copy.releaseTitle}</h2>
        <p>{copy.pendingBody}</p>
        <div class="hero-actions">
          <a class="button primary" href={href("/start.html")}>{copy.demo}</a>
          <a class="button" href={href("/research.html")}>{copy.research}</a>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
