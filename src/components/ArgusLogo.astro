---
import horizontalSource from "../../public/assets/argus-logo-rounded-horizontal.svg?raw";
import markSource from "../../public/assets/argus-mark-rounded.svg?raw";
import smallSource from "../../public/assets/argus-mark-rounded-small.svg?raw";

type Props = {
  variant?: "horizontal" | "mark" | "small";
  class?: string;
  label?: string;
  decorative?: boolean;
};

const {
  variant = "horizontal",
  class: className = "",
  label = "Argus",
  decorative = false,
} = Astro.props;
const sources = { horizontal: horizontalSource, mark: markSource, small: smallSource };
const gradientId = `argus-rounded-${variant}-${className.replace(/[^a-z0-9_-]/gi, "-") || "default"}`;
const gradientStart = variant === "horizontal" ? 180 : 66;
const gradientEnd = variant === "horizontal" ? 1280 : 440;
const definitions = `<defs><linearGradient id="${gradientId}" gradientUnits="userSpaceOnUse" x1="${gradientStart}" y1="0" x2="${gradientEnd}" y2="0"><stop offset="0%" stop-color="var(--blue-dark)"/><stop offset="52%" stop-color="var(--blue)"/><stop offset="100%" stop-color="var(--gold-dark)"/></linearGradient></defs>`;
const svg = sources[variant]
  .replace(/<title>[\s\S]*?<\/title>/, "")
  .replace(/\srole="img"/, "")
  .replace("<svg ", `<svg class="argus-logo__svg" aria-hidden="true" focusable="false" `)
  .replace(">", `>${definitions}`)
  .replaceAll("currentColor", `url(#${gradientId})`);
---

<span
  class:list={["argus-logo", className]}
  data-argus-logo={variant}
  role={decorative ? undefined : "img"}
  aria-label={decorative ? undefined : label}
  aria-hidden={decorative ? "true" : undefined}
  set:html={svg}
></span>
