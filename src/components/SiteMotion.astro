<script>
  const root = document.documentElement;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const revealSelector = [
    ".section-head",
    ".card",
    ".metric",
    ".score-row",
    ".role",
    ".pipeline > div",
    ".figure",
    ".cta-band",
    ".demo-intro",
    ".demo-frame",
    ".demo-caption",
    ".demo-points > span",
    ".runtime-flow__track > div",
  ].join(",");
  const resetMotionStyles = () => {
    document.querySelectorAll<HTMLElement>(revealSelector).forEach((element) => {
      element.style.removeProperty("opacity");
      element.style.removeProperty("visibility");
      element.style.removeProperty("transform");
    });
  };

  if (reduceMotion) {
    root.classList.remove("motion-prep");
  } else {
    void import("gsap").then(({ gsap }) => {
      const heroTargets = gsap.utils.toArray<HTMLElement>(
        ".page-hero .eyebrow, .page-hero h1, .page-hero .lede, .page-hero .hero-actions, .page-hero .demo-source, [data-research-field]",
      );
      const revealTargets = gsap.utils.toArray<HTMLElement>(revealSelector);
      const canObserve = "IntersectionObserver" in window;
      const pointerCleanups: Array<() => void> = [];
      const finePointer = window.matchMedia("(pointer: fine) and (hover: hover)").matches;
      const coarsePointer = window.matchMedia("(pointer: coarse), (hover: none)").matches;
      const pointerSurfaces = new WeakSet<Element>();

      const attachPointerSurface = (surface: HTMLElement) => {
        if (!finePointer || pointerSurfaces.has(surface)) return;
        pointerSurfaces.add(surface);
        const move = (event: PointerEvent) => {
          const rect = surface.getBoundingClientRect();
          surface.style.setProperty("--pointer-x", `${event.clientX - rect.left}px`);
          surface.style.setProperty("--pointer-y", `${event.clientY - rect.top}px`);
          if (surface.matches(".card, .paper-card, .role, .launch-command")) {
            rotateYTo(((event.clientX - rect.left) / rect.width - 0.5) * 4.5);
            rotateXTo(-((event.clientY - rect.top) / rect.height - 0.5) * 3.5);
          }
        };
        const rotateXTo = gsap.quickTo(surface, "rotationX", {
          duration: 0.38,
          ease: "power3.out",
        });
        const rotateYTo = gsap.quickTo(surface, "rotationY", {
          duration: 0.38,
          ease: "power3.out",
        });
        const enter = () => gsap.to(surface, {
          "--spotlight-opacity": 1,
          duration: 0.2,
          ease: "power1.out",
          overwrite: "auto",
        });
        const leave = () => {
          gsap.to(surface, {
            "--spotlight-opacity": 0,
            rotationX: 0,
            rotationY: 0,
            duration: 0.42,
            ease: "power2.out",
            overwrite: "auto",
            clearProps: "transform",
          });
        };
        surface.addEventListener("pointermove", move);
        surface.addEventListener("pointerenter", enter);
        surface.addEventListener("pointerleave", leave);
        pointerCleanups.push(() => {
          surface.removeEventListener("pointermove", move);
          surface.removeEventListener("pointerenter", enter);
          surface.removeEventListener("pointerleave", leave);
        });
      };

      if (finePointer) {
        const cursorDot = document.createElement("span");
        const cursorRing = document.createElement("span");
        cursorDot.className = "argus-cursor-dot";
        cursorRing.className = "argus-cursor-ring";
        cursorDot.setAttribute("aria-hidden", "true");
        cursorRing.setAttribute("aria-hidden", "true");
        document.body.append(cursorRing, cursorDot);
        gsap.set([cursorDot, cursorRing], { xPercent: -50, yPercent: -50 });
        const ringX = gsap.quickTo(cursorRing, "x", { duration: 0.32, ease: "power3.out" });
        const ringY = gsap.quickTo(cursorRing, "y", { duration: 0.32, ease: "power3.out" });
        const ambientMove = (event: PointerEvent) => {
          document.body.style.setProperty("--ambient-x", `${event.clientX}px`);
          document.body.style.setProperty("--ambient-y", `${event.clientY}px`);
          gsap.set(cursorDot, { x: event.clientX, y: event.clientY, autoAlpha: 1 });
          ringX(event.clientX);
          ringY(event.clientY);
          gsap.to(cursorRing, { autoAlpha: 1, duration: 0.18, overwrite: "auto" });
        };
        const cursorOver = (event: PointerEvent) => {
          const interactive = (event.target as Element | null)?.closest(
            "a, button, .card, .score-row, .role, .paper-card, [data-research-field-plane]",
          );
          cursorRing.classList.toggle("active", Boolean(interactive));
          gsap.to(cursorRing, {
            scale: interactive ? 1.55 : 1,
            duration: 0.25,
            ease: "power2.out",
            overwrite: "auto",
          });
        };
        const cursorDown = () => gsap.fromTo(cursorRing, { scale: 0.72 }, {
          scale: cursorRing.classList.contains("active") ? 1.55 : 1,
          duration: 0.38,
          ease: "back.out(2.4)",
          overwrite: "auto",
        });
        const cursorHide = () => gsap.to([cursorDot, cursorRing], {
          autoAlpha: 0,
          duration: 0.2,
          overwrite: "auto",
        });
        window.addEventListener("pointermove", ambientMove, { passive: true });
        document.addEventListener("pointerover", cursorOver, { passive: true });
        document.addEventListener("pointerdown", cursorDown, { passive: true });
        document.documentElement.addEventListener("mouseleave", cursorHide);
        pointerCleanups.push(() => {
          window.removeEventListener("pointermove", ambientMove);
          document.removeEventListener("pointerover", cursorOver);
          document.removeEventListener("pointerdown", cursorDown);
          document.documentElement.removeEventListener("mouseleave", cursorHide);
          cursorDot.remove();
          cursorRing.remove();
        });
        document.querySelectorAll<HTMLElement>(
          ".page-hero, .card, .score-row, .role, .launch-command, .paper-card",
        ).forEach(attachPointerSurface);
        document.querySelectorAll<HTMLElement>(".button.primary, .site-start").forEach((element) => {
          const xTo = gsap.quickTo(element, "x", { duration: 0.3, ease: "power3.out" });
          const yTo = gsap.quickTo(element, "y", { duration: 0.3, ease: "power3.out" });
          const move = (event: PointerEvent) => {
            const rect = element.getBoundingClientRect();
            xTo((event.clientX - (rect.left + rect.width / 2)) * 0.12);
            yTo((event.clientY - (rect.top + rect.height / 2)) * 0.16);
          };
          const leave = () => gsap.to(element, {
            x: 0,
            y: 0,
            duration: 0.42,
            ease: "elastic.out(1, 0.45)",
            clearProps: "transform",
          });
          element.addEventListener("pointermove", move);
          element.addEventListener("pointerleave", leave);
          pointerCleanups.push(() => {
            element.removeEventListener("pointermove", move);
            element.removeEventListener("pointerleave", leave);
          });
        });
      }
      if (coarsePointer) {
        const touchPress = (event: PointerEvent) => {
          if (event.pointerType === "mouse") return;
          const target = (event.target as Element | null)?.closest<HTMLElement>(
            ".card, .paper-card, .role, .button, .site-start, [data-research-field-plane]",
          );
          if (!target) return;
          gsap.fromTo(target, { scale: 0.985 }, {
            scale: 1,
            duration: 0.36,
            ease: "back.out(2.2)",
            clearProps: "scale",
            overwrite: "auto",
          });
          if (target.matches("[data-research-field-plane]")) {
            gsap.fromTo("[data-research-field-node]", { scale: 0.9 }, {
              scale: 1,
              duration: 0.4,
              stagger: 0.055,
              ease: "back.out(2)",
              clearProps: "scale",
            });
          }
        };
        document.addEventListener("pointerdown", touchPress, { passive: true });
        pointerCleanups.push(() => document.removeEventListener("pointerdown", touchPress));
      }

      const progress = document.querySelector<HTMLElement>("[data-scroll-progress]");
      if (progress) {
        const progressTo = gsap.quickTo(progress, "scaleX", {
          duration: 0.22,
          ease: "power1.out",
        });
        const updateProgress = () => {
          const range = document.documentElement.scrollHeight - window.innerHeight;
          progressTo(range > 0 ? window.scrollY / range : 0);
        };
        window.addEventListener("scroll", updateProgress, { passive: true });
        window.addEventListener("resize", updateProgress);
        updateProgress();
        pointerCleanups.push(() => {
          window.removeEventListener("scroll", updateProgress);
          window.removeEventListener("resize", updateProgress);
        });
      }

      const researchField = document.querySelector<HTMLElement>("[data-research-field]");
      const researchPlane = document.querySelector<HTMLElement>("[data-research-field-plane]");
      if (researchField) {
        gsap.to(".research-field__link", {
          strokeDashoffset: -72,
          duration: 4.8,
          ease: "none",
          repeat: -1,
        });
        gsap.to("[data-research-field-scan]", {
          rotation: 360,
          duration: 12,
          ease: "none",
          repeat: -1,
          transformOrigin: "50% 50%",
        });
        gsap.to("[data-research-field-core]", {
          scale: 1.035,
          duration: 1.7,
          ease: "sine.inOut",
          yoyo: true,
          repeat: -1,
          transformOrigin: "50% 50%",
        });
        gsap.to("[data-research-field-node]", {
          y: (index) => index % 2 === 0 ? -5 : 5,
          duration: 2.2,
          stagger: 0.18,
          ease: "sine.inOut",
          yoyo: true,
          repeat: -1,
        });
        gsap.to("[data-research-field-particle]", {
          x: "random(-10, 10)",
          y: "random(-9, 9)",
          scale: "random(0.7, 1.45)",
          opacity: "random(0.32, 0.9)",
          duration: "random(1.8, 3.6)",
          stagger: 0.11,
          ease: "sine.inOut",
          yoyo: true,
          repeat: -1,
          repeatRefresh: true,
        });
      }
      if (finePointer && researchPlane) {
        const rotateXTo = gsap.quickTo(researchPlane, "rotationX", { duration: 0.6, ease: "power3.out" });
        const rotateYTo = gsap.quickTo(researchPlane, "rotationY", { duration: 0.6, ease: "power3.out" });
        const fieldMove = (event: PointerEvent) => {
          const rect = researchPlane.getBoundingClientRect();
          rotateYTo(((event.clientX - rect.left) / rect.width - 0.5) * 5);
          rotateXTo(-((event.clientY - rect.top) / rect.height - 0.5) * 4);
        };
        const fieldLeave = () => gsap.to(researchPlane, {
          rotationX: 0,
          rotationY: 0,
          duration: 0.7,
          ease: "power3.out",
          clearProps: "transform",
        });
        researchPlane.addEventListener("pointermove", fieldMove);
        researchPlane.addEventListener("pointerleave", fieldLeave);
        pointerCleanups.push(() => {
          researchPlane.removeEventListener("pointermove", fieldMove);
          researchPlane.removeEventListener("pointerleave", fieldLeave);
        });
      }

      gsap.set(heroTargets, { autoAlpha: 0, y: 24 });
      if (canObserve) gsap.set(revealTargets, { autoAlpha: 0, y: 20 });
      root.classList.remove("motion-prep");

      gsap.timeline({ defaults: { ease: "power3.out" } })
        .fromTo(".site-header", { autoAlpha: 0, y: -12 }, { autoAlpha: 1, y: 0, duration: 0.42 })
        .to(heroTargets, {
          autoAlpha: 1,
          y: 0,
          duration: 0.68,
          stagger: 0.09,
          clearProps: "transform,opacity,visibility",
        }, 0.06);

      const observer = canObserve ? new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          observer?.unobserve(entry.target);
          const targets = [...entry.target.querySelectorAll<HTMLElement>(revealSelector)];
          if (!targets.length) continue;
          gsap.to(targets, {
            autoAlpha: 1,
            y: 0,
            duration: 0.62,
            stagger: { amount: Math.min(0.48, targets.length * 0.07) },
            ease: "power2.out",
            clearProps: "transform,opacity,visibility",
          });
        }
      }, { rootMargin: "0px 0px -10% 0px", threshold: 0.08 }) : null;

      if (observer) {
        document.querySelectorAll<HTMLElement>(".metric-strip, .runtime-flow, .section")
          .forEach((section) => observer.observe(section));
      }

      const animatedCards = new WeakSet<Element>();
      const animatePaperCards = () => {
        const cards = [...document.querySelectorAll<HTMLElement>(".paper-card")]
          .filter((card) => !animatedCards.has(card));
        cards.forEach((card) => animatedCards.add(card));
        cards.forEach(attachPointerSurface);
        if (!cards.length) return;
        gsap.fromTo(cards, { autoAlpha: 0, y: 16 }, {
          autoAlpha: 1,
          y: 0,
          duration: 0.5,
          stagger: { amount: Math.min(0.4, cards.length * 0.04) },
          ease: "power2.out",
          clearProps: "transform,opacity,visibility",
        });
      };
      const mutationObserver = "MutationObserver" in window
        ? new MutationObserver(animatePaperCards)
        : null;
      mutationObserver?.observe(document.body, { childList: true, subtree: true });
      animatePaperCards();
      window.addEventListener("pagehide", (event) => {
        if (event.persisted) return;
        observer?.disconnect();
        mutationObserver?.disconnect();
        pointerCleanups.forEach((cleanup) => cleanup());
      }, { once: true });
    }).catch(() => {
      root.classList.remove("motion-prep");
      resetMotionStyles();
    });
  }
</script>
